# EditorConfig for SpecValidator
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,txt,yml,yaml,json,jsonc}]
indent_size = 2

[*.{py,pyi,pyx,pxd,pxi}]
indent_size = 4

[*.{js,jsx,ts,tsx,css,scss,html}]
indent_size = 2

[*.{sh,bash,zsh,ps1}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{toml,ini,cfg}]
indent_size = 2

[*.{dockerfile,Dockerfile}]
indent_size = 4