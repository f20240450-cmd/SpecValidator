# SpecValidator Docker Ignore
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Documentation (not needed in container)
*.md
!README.md
docs/
*.rst

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/
pip-wheel-metadata/
*.egg-info/
dist/
build/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build (we build in container)
frontend/build/
frontend/.cache/

# Environment files
.env
.env.local
.env.*.local
*.env

# Model files (downloaded at runtime or mounted)
models/
*.gguf
*.bin
*.pt
*.pth

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Test outputs
test-results/
coverage/
.nyc_output/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Spec Kit (not needed in container)
.specify/
.opencode/
specs/

# CI/CD
.gitlab-ci.yml
.github/

# Misc
*.backup
*.bak
*.orig