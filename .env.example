# SpecValidator Environment Configuration Example
# Copy this file to .env and customize for your environment

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Path to the GGUF model file (downloaded by download_model.py)
MODEL_PATH=./models/phi-4-mini-instruct-q4_k_m.gguf

# Number of CPU threads for inference (default: CPU cores / 2)
MODEL_THREADS=8

# Context window size (tokens) - lower for less memory, higher for more context
MODEL_CONTEXT=2048

# Temperature for sampling (0.0 = deterministic, 1.0 = creative)
MODEL_TEMPERATURE=0.2

# Top-p sampling (nucleus sampling)
MODEL_TOP_P=0.9

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Host to bind the server to
HOST=0.0.0.0

# Port for the FastAPI server
PORT=8000

# Number of worker processes (for production with gunicorn)
WORKERS=4

# Enable debug mode (more verbose logging, auto-reload)
DEBUG=false

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Maximum file size in bytes (10 MB default)
MAX_FILE_SIZE=10485760

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.md,.txt,.pdf,.docx,.doc

# Temporary directory for file processing
TEMP_DIR=/tmp/specvalidator

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# Log file path (optional, leave empty for stdout only)
LOG_FILE=

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated, * for all)
# In production, restrict to your frontend domain
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# GRAMMAR CONFIGURATION
# =============================================================================

# Path to grammar files directory
GRAMMAR_DIR=./grammars

# Default grammar file for endpoint validation
DEFAULT_GRAMMAR=endpoint.gbnf

# =============================================================================
# PROCESSING CONFIGURATION
# =============================================================================

# Timeout per section in seconds
SECTION_TIMEOUT=120

# Maximum concurrent section workers
MAX_WORKERS=4

# Enable parallel processing
ENABLE_PARALLEL=true

# =============================================================================
# FRONTEND CONFIGURATION (for reference)
# =============================================================================

# Frontend development server port
FRONTEND_PORT=3000

# API base URL for frontend (proxy configured in package.json)
REACT_APP_API_URL=http://localhost:8000

# =============================================================================
# OPTIONAL: GPU ACCELERATION (requires llama-cpp-python[cu121] or similar)
# =============================================================================

# Number of GPU layers to offload (0 = CPU only)
# GPU_LAYERS=0

# =============================================================================
# OPTIONAL: MODEL CACHE
# =============================================================================

# Cache directory for downloaded models
# MODEL_CACHE_DIR=~/.cache/specvalidator/models

# =============================================================================
# NOTES
# =============================================================================
# - All paths are relative to the backend directory unless absolute
# - Comments start with # and are ignored
# - Boolean values: true/false (lowercase)
# - Restart the server after changing these values
# - For production, use a proper secrets management solution